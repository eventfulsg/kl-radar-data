<style>
  :root{
    --orange:#F26F21;
    --red:#C41230;
    --pressed:#C93D6E;--peachside:#E07E27;
    --cream:#F3EADB;
    --ink:#2B2521;
    --white:#FFFFFF;
  }
  *{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
  body{
    font-family:'Jost',sans-serif;
    background:var(--cream);
    color:var(--ink);
    position:relative;
    overflow-x:hidden;
    min-height:100vh;
  }
  .page{position:relative;z-index:1;}
  .wrap{max-width:480px;margin:0 auto;padding:0 18px;}
  img{max-width:100%;display:block;}
  a{color:inherit;text-decoration:none;}

  /* draft banner */
  .draft-bar{
    background:var(--ink);color:var(--white);
    font-size:12px;font-weight:600;letter-spacing:.04em;
    text-align:center;padding:9px 16px;line-height:1.5;
  }
  .draft-bar b{color:#FFC94A;font-weight:800;letter-spacing:.1em;}

  /* ============ NAV ============ */
  .nav{
    display:flex;align-items:center;justify-content:space-between;
    padding:16px 18px;max-width:480px;margin:0 auto;
  }
  .logo{display:flex;align-items:center;gap:7px;}
  .logo img{height:26px;width:auto;display:block;}
  .logo-drops{
    font-weight:700;font-size:15px;
    color:var(--ink);letter-spacing:.14em;text-transform:uppercase;
    padding-top:2px;
  }
  .nav-pill{
    font-weight:700;font-size:11px;
    background:var(--pressed);color:var(--white);
    border-radius:999px;padding:6px 12px;letter-spacing:.04em;
  }

  .pills{display:flex;gap:8px;flex-wrap:wrap;}
  .pill{
    font-weight:700;font-size:12px;
    border-radius:999px;padding:6px 14px;
  }
  .pill.red{background:var(--pressed);color:var(--white);}

  .btn{
    display:block;width:100%;border:none;cursor:pointer;
    font-family:'Jost',sans-serif;font-weight:800;font-size:18px;
    border-radius:999px;padding:16px;text-align:center;
    transition:transform .1s;
  }
  .btn:active{transform:scale(.98);}
  .btn.primary{background:var(--orange);color:var(--white);box-shadow:0 8px 22px rgba(242,111,33,.4);}

  /* ============ PRODUCT ============ */
  .prod-img{
    border-radius:24px;aspect-ratio:1/1;position:relative;overflow:hidden;
    background:#F3EADB;margin-bottom:18px;
  }
  .prod-img img{width:100%;height:100%;object-fit:cover;display:block;}
  .flash{position:absolute;top:12px;left:12px;}
  .prod-img img.hero-badge{
    position:absolute;right:14px;bottom:14px;width:88px;height:88px;
    left:auto;top:auto;object-fit:contain;
    border-radius:50%;box-shadow:0 6px 18px rgba(43,32,23,.3);
    border:3px solid var(--white);
  }
  .prod-title{font-size:28px;font-weight:800;line-height:1.1;margin-bottom:6px;}
  .prod-collab{display:flex;align-items:center;gap:9px;font-size:13px;font-weight:600;color:#6b6259;margin-bottom:14px;}
  .prod-collab b{color:var(--pressed);}
  .prod-collab .logos{display:flex;flex-shrink:0;}
  .prod-collab .logos img{width:30px;height:30px;border-radius:50%;border:2px solid var(--white);box-shadow:0 2px 8px rgba(43,32,23,.16);display:block;}
  .prod-collab .logos img+img{margin-left:-8px;}
  .price-row{display:flex;align-items:baseline;gap:10px;margin-bottom:18px;}
  .price{font-weight:800;font-size:32px;color:var(--ink);}
  .price-note{font-size:12.5px;color:#6b6259;font-weight:500;}

  .includes{background:var(--white);border-radius:20px;padding:18px;margin-bottom:14px;}
  .includes h3{font-size:16px;margin-bottom:12px;}
  .inc-item{
    display:flex;gap:10px;align-items:flex-start;
    font-size:13.5px;line-height:1.5;margin-bottom:10px;color:#443c35;
  }
  .inc-item:last-child{margin-bottom:0;}
  .inc-check{color:var(--orange);font-weight:800;flex-shrink:0;}

  .redeem-strip{background:var(--ink);border-radius:20px;padding:18px;margin-bottom:14px;}
  .redeem-strip h3{color:var(--white);font-size:15px;margin-bottom:10px;}
  .redeem-strip p{color:rgba(255,255,255,.72);font-size:13px;line-height:1.6;}
  .redeem-strip p b{color:var(--orange);}

  /* story cards */
  .story{background:var(--white);border-radius:20px;overflow:hidden;margin-bottom:14px;}
  .story img{width:100%;aspect-ratio:16/10;object-fit:cover;}
  .story .story-body{padding:16px 18px 18px;}
  .story h3{font-size:16px;margin-bottom:8px;}
  .story p{font-size:13.5px;line-height:1.6;color:#443c35;}
