  .bg-scatter{position:absolute;inset:0;overflow:hidden;z-index:0;pointer-events:none;}
  .bg-shape{position:absolute;}
  .bg-shape svg{width:100%;height:100%;display:block;overflow:visible;}

  .acct-btn{display:inline-flex;align-items:center;gap:5px;font-family:'Jost',sans-serif;font-weight:700;font-size:12.5px;
    background:var(--ink);color:var(--white);border-radius:999px;padding:7px 15px;white-space:nowrap;transition:transform .1s,opacity .15s;}
  .acct-btn:hover{opacity:.88;}
  .acct-btn svg{width:14px;height:14px;}

  /* demo toast */
  .toast{
    position:fixed;left:50%;bottom:26px;transform:translateX(-50%) translateY(20px);
    background:var(--ink);color:var(--white);font-size:13px;font-weight:600;
    border-radius:999px;padding:11px 20px;opacity:0;pointer-events:none;
    transition:opacity .25s, transform .25s;z-index:50;white-space:nowrap;
  }
  .toast.show{opacity:1;transform:translateX(-50%) translateY(0);}

  /* feud tally (drop-004 only) */
  .feud-bar{display:flex;height:12px;border-radius:999px;overflow:hidden;background:#EDE2CF;margin:12px 0 6px;}
  .feud-bar .fp{background:var(--pressed);}
  .feud-bar .fh{background:var(--peachside);}
  .feud-counts{display:flex;justify-content:space-between;font-size:11.5px;font-weight:700;}
  .feud-counts .cp{color:var(--pressed);}
  .feud-counts .ch{color:var(--peachside);}
  .side-price{display:block;font-weight:800;font-size:15px;margin-top:3px;}
  .side-sorry{font-size:10px;font-weight:700;color:var(--peachside);letter-spacing:.03em;}
</style>
