<style>
  :root{
    --orange:#F26F21;
    --red:#C41230;
    --cream:#F3EADB;
    --ink:#2B2521;
    --white:#FFFFFF;
    --pastel-pink:#F5C9C9;
    --pastel-gold:#EBD9A8;
    --pastel-teal:#BFDCD4;
  }
  *{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
  body{
    font-family:'Jost',sans-serif;
    background:var(--cream);
    color:var(--ink);
    position:relative;
    overflow-x:hidden;
    min-height:100vh;
  }
  .bg{position:absolute;inset:0;overflow:hidden;z-index:0;pointer-events:none;}
  .blob{position:absolute;border-radius:50%;filter:blur(70px);opacity:.35;}

  .page{position:relative;z-index:1;}
  .wrap{max-width:480px;margin:0 auto;padding:0 18px;}
  img{max-width:100%;display:block;}
  a{color:inherit;text-decoration:none;}

  /* ============ NAV ============ */
  .nav{
    display:flex;align-items:center;justify-content:space-between;
    padding:16px 18px;max-width:480px;margin:0 auto;
  }
  .logo{display:flex;align-items:center;gap:7px;}
  .logo img{height:26px;width:auto;display:block;}
  .logo-drops{
    font-weight:700;font-size:15px;
    color:var(--ink);letter-spacing:.14em;text-transform:uppercase;
    padding-top:2px;
  }
  .nav-pill{
    font-weight:700;font-size:11px;
    background:var(--ink);color:var(--white);
    border-radius:999px;padding:6px 12px;letter-spacing:.04em;
  }

  .pills{display:flex;gap:8px;flex-wrap:wrap;}
  .pill{
    font-weight:700;font-size:12px;
    border-radius:999px;padding:6px 14px;
  }
  .pill.orange{background:var(--orange);color:var(--white);}
  .pill.red{background:var(--red);color:var(--white);}

  .btn{
    display:block;width:100%;border:none;cursor:pointer;
    font-family:'Jost',sans-serif;font-weight:800;font-size:18px;
    border-radius:999px;padding:16px;text-align:center;
    transition:transform .1s;
  }
  .btn:active{transform:scale(.98);}
  .btn.primary{background:var(--orange);color:var(--white);box-shadow:0 8px 22px rgba(242,111,33,.4);}
  .btn.ink{background:var(--ink);color:var(--white);}
  .btn.ghost{background:transparent;border:2px solid var(--ink);color:var(--ink);font-size:16px;padding:13px;}

  .screen{display:none;min-height:70vh;}
  .screen.active{display:block;}

  .back-link{
    font-size:13px;font-weight:600;color:#6b6259;
    padding:4px 0 12px;display:inline-block;cursor:pointer;
  }

  /* ============ PRODUCT ============ */
  .prod-img{
    border-radius:24px;aspect-ratio:1/1;position:relative;overflow:hidden;
    background:#F3EADB;margin-bottom:18px;
  }
  .prod-img img{width:100%;height:100%;object-fit:cover;display:block;}
  .flash{position:absolute;top:12px;left:12px;}
  .prod-title{font-size:28px;font-weight:800;line-height:1.1;margin-bottom:6px;}
  .prod-collab{display:flex;align-items:center;gap:9px;font-size:13px;font-weight:600;color:#6b6259;margin-bottom:14px;}
  .prod-collab b{color:var(--red);}
  .prod-collab .logos{display:flex;flex-shrink:0;}
  .prod-collab .logos img{width:30px;height:30px;border-radius:50%;border:2px solid var(--white);box-shadow:0 2px 8px rgba(43,32,23,.16);display:block;}
  .prod-collab .logos img+img{margin-left:-8px;}
  .price-row{display:flex;align-items:baseline;gap:10px;margin-bottom:18px;}
  .price{font-weight:800;font-size:32px;color:var(--ink);}
  .price-note{font-size:12.5px;color:#6b6259;font-weight:500;}

  .includes{background:var(--white);border-radius:20px;padding:18px;margin-bottom:14px;}
  .includes h3{font-size:16px;margin-bottom:12px;}
  .inc-item{
    display:flex;gap:10px;align-items:flex-start;
    font-size:13.5px;line-height:1.5;margin-bottom:10px;color:#443c35;
  }
  .inc-item:last-child{margin-bottom:0;}
  .inc-check{color:var(--orange);font-weight:800;flex-shrink:0;}

  .redeem-strip{background:var(--ink);border-radius:20px;padding:18px;margin-bottom:18px;}
  .redeem-strip h3{color:var(--white);font-size:15px;margin-bottom:10px;}
  .redeem-strip p{color:rgba(255,255,255,.72);font-size:13px;line-height:1.6;}
  .redeem-strip p b{color:var(--orange);}

  .qty-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;}
  .qty-label{font-weight:700;font-size:15px;}
  .qty-cap{font-size:11px;color:#6b6259;font-weight:500;}
  .qty-ctrl{
    display:flex;align-items:center;gap:16px;
    background:var(--white);border-radius:999px;padding:8px 16px;
  }
  .qty-btn{
    width:30px;height:30px;border-radius:50%;border:none;
    background:var(--cream);font-size:18px;font-weight:700;cursor:pointer;
    font-family:'Jost',sans-serif;color:var(--ink);
  }
  .qty-num{font-weight:800;font-size:18px;min-width:20px;text-align:center;}
  .sticky-cta{
    position:sticky;bottom:0;padding:12px 0 18px;
    background:linear-gradient(180deg,transparent,var(--cream) 30%);
  }

  /* ============ CHECKOUT ============ */
  .co-head{padding:6px 0 18px;}
  .co-head h1{font-size:26px;font-weight:800;}
  .co-summary{
    background:var(--white);border-radius:20px;padding:16px 18px;
    display:flex;justify-content:space-between;align-items:center;
    margin-bottom:18px;
  }
  .co-summary .l b{font-size:15px;display:block;}
  .co-summary .l span{font-size:12px;color:#6b6259;}
  .co-summary .r{font-weight:800;font-size:20px;}
  .form-group{margin-bottom:12px;}
  .form-group label{
    display:block;font-size:12px;font-weight:600;letter-spacing:.04em;
    text-transform:uppercase;color:#6b6259;margin-bottom:6px;
  }
  .form-group input{
    width:100%;border:2px solid #E5D9C6;border-radius:14px;
    padding:13px 15px;font-size:15px;font-family:'Jost',sans-serif;
    background:var(--white);color:var(--ink);outline:none;
  }
  .form-group input:focus{border-color:var(--orange);}
  .form-note{font-size:11.5px;color:#6b6259;margin-top:5px;line-height:1.5;}

  .pay-title{font-weight:700;font-size:15px;margin:20px 0 10px;}
  .pay-opt{
    display:flex;align-items:center;gap:12px;
    background:var(--white);border:2px solid #E5D9C6;border-radius:16px;
    padding:14px 16px;margin-bottom:10px;cursor:pointer;
  }
  .pay-opt.selected{border-color:var(--orange);background:#FFF7EF;}
  .pay-radio{width:20px;height:20px;border-radius:50%;border:2px solid #C9BBA4;flex-shrink:0;}
  .pay-opt.selected .pay-radio{border:6px solid var(--orange);}
  .pay-name{font-weight:600;font-size:14.5px;flex:1;}
  .pay-badge{font-size:10px;font-weight:700;letter-spacing:.05em;color:var(--white);background:var(--red);border-radius:6px;padding:3px 7px;}
  .pay-ico{font-size:20px;}
  .co-legal{font-size:11px;color:#8a8177;line-height:1.6;margin:14px 0 80px;}

  /* ============ TICKET ============ */
  .done-head{text-align:center;padding:22px 0 20px;}
  .done-head .big{font-size:44px;}
  .done-head h1{font-size:28px;font-weight:800;margin-top:6px;}
  .done-head p{font-size:14px;color:#6b6259;margin-top:6px;}

  .ticket{
    background:var(--white);border-radius:24px;overflow:hidden;
    box-shadow:0 12px 32px rgba(43,37,33,.12);
    position:relative;
  }
  .ticket-top{background:var(--orange);padding:20px;color:var(--white);}
  .ticket-top .t-label{font-size:10px;letter-spacing:.12em;text-transform:uppercase;font-weight:700;opacity:.85;}
  .ticket-top h2{font-size:22px;font-weight:800;line-height:1.15;margin-top:4px;}
  .ticket-num{
    font-weight:800;font-size:15px;
    background:rgba(255,255,255,.2);border-radius:999px;
    display:inline-block;padding:4px 14px;margin-top:10px;
  }
  .perf{height:0;border-top:2px dashed #E5D9C6;position:relative;margin:0 14px;}
  .perf::before,.perf::after{
    content:'';position:absolute;top:-11px;width:22px;height:22px;border-radius:50%;
    background:var(--cream);
  }
  .perf::before{left:-25px;}
  .perf::after{right:-25px;}
  .ticket-bottom{padding:22px 20px;text-align:center;}
  .qr{
    width:150px;height:150px;margin:0 auto 14px;
    border-radius:16px;background:
      repeating-linear-gradient(0deg,var(--ink) 0 6px,transparent 6px 12px),
      repeating-linear-gradient(90deg,var(--ink) 0 6px,var(--white) 6px 12px);
    border:8px solid var(--white);outline:2px solid #E5D9C6;
    position:relative;
  }
  .qr::after{
    content:'QR';position:absolute;inset:0;display:flex;align-items:center;justify-content:center;
    font-weight:800;font-size:22px;color:var(--white);
    background:var(--orange);width:44px;height:44px;border-radius:12px;margin:auto;
  }
  .ticket-bottom .r-line{font-size:13px;color:#443c35;line-height:1.65;}
  .ticket-bottom .r-line b{color:var(--red);}

  .done-info{background:var(--white);border-radius:20px;padding:18px;margin:16px 0;}
  .done-info .row{
    display:flex;justify-content:space-between;
    font-size:13.5px;padding:7px 0;border-bottom:1px solid #F0E7D6;
  }
  .done-info .row:last-child{border:none;}
  .done-info .row span:first-child{color:#6b6259;font-weight:500;}
  .done-info .row span:last-child{font-weight:600;}
  .done-actions{display:flex;flex-direction:column;gap:10px;padding-bottom:40px;}

  .foot{text-align:center;padding:10px 0 34px;font-size:11.5px;color:#8a8177;}
  .foot b{color:var(--ink);}

  /* ============ DESKTOP ============ */
  @media (min-width: 900px){
    .nav{max-width:1020px;padding:20px 18px;}
    .screen .wrap{max-width:1020px;display:grid;grid-template-columns:1fr 1fr;gap:0 48px;align-items:start;}
    .screen .wrap > *{grid-column:2;}
    .screen .wrap > .back-link{grid-column:1/-1;}
    .screen .wrap > .prod-img{grid-column:1;grid-row:2 / span 10;position:sticky;top:24px;height:auto;margin-bottom:0;}
    .prod-title{font-size:38px;}
    .price{font-size:40px;}
    .sticky-cta{position:static;background:none;padding:14px 0 40px;}
    .foot{max-width:1020px;margin:0 auto;}
  }

  /* deck-style textured background */
  body{background-image:url('data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22240%22%20height%3D%22240%22%3E%3Cfilter%20id%3D%22n%22%3E%3CfeTurbulence%20type%3D%22fractalNoise%22%20baseFrequency%3D%220.8%22%20numOctaves%3D%222%22%20stitchTiles%3D%22stitch%22%2F%3E%3CfeColorMatrix%20type%3D%22matrix%22%20values%3D%220%200%200%200%200.42%200%200%200%200%200.35%200%200%200%200%200.27%200%200%200%200.10%200%22%2F%3E%3C%2Ffilter%3E%3Crect%20width%3D%22240%22%20height%3D%22240%22%20filter%3D%22url%28%23n%29%22%2F%3E%3C%2Fsvg%3E');}
  .bg-scatter{position:absolute;inset:0;overflow:hidden;z-index:0;pointer-events:none;}
  .bg-shape{position:absolute;}
  .bg-shape svg{width:100%;height:100%;display:block;overflow:visible;}

  .acct-btn{display:inline-flex;align-items:center;gap:5px;font-family:'Jost',sans-serif;font-weight:700;font-size:12.5px;
    background:var(--ink);color:var(--white);border-radius:999px;padding:7px 15px;white-space:nowrap;transition:transform .1s,opacity .15s;}
  .acct-btn:hover{opacity:.88;}
  .acct-btn svg{width:14px;height:14px;}
</style>
</head>
<body>
<div class="bg-scatter" id="bgScatter" aria-hidden="true"></div>

<div class="page">
