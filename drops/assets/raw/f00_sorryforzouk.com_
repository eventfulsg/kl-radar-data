        this.cards = this.querySelectorAll('.nw-custom-image-card-adklyeviwz2fyl2dxdaigenblocka4b6ec7k7bpbw');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.cards.forEach((card) => {
          card.addEventListener('click', (e) => {
            const href = card.getAttribute('href');
            if (href === '#') {
              e.preventDefault();
            }
          });
        });
      }
    }

    customElements.define('image-cards-adklyeviwz2fyl2dxdaigenblocka4b6ec7k7bpbw', ImageCardsadklyeviwz2fyl2dxdaigenblocka4b6ec7k7bpbw);
