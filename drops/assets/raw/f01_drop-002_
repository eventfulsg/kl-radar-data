<style>
  :root{
    --orange:#F26F21;
    --red:#C41230;
    --pressed:#BE2B26;
    --cream:#F3EADB;
    --ink:#2B2521;
    --white:#FFFFFF;
  }
  *{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
  body{
    font-family:'Jost',sans-serif;
    background:var(--cream);
    color:var(--ink);
    position:relative;
    overflow-x:hidden;
    min-height:100vh;
  }
  .page{position:relative;z-index:1;}
  .wrap{max-width:480px;margin:0 auto;padding:0 18px;}
  img{max-width:100%;display:block;}
  a{color:inherit;text-decoration:none;}

  /* draft banner */
  .draft-bar{
    background:var(--ink);color:var(--white);
    font-size:12px;font-weight:600;letter-spacing:.04em;
    text-align:center;padding:9px 16px;line-height:1.5;
  }
  .draft-bar b{color:#FFC94A;font-weight:800;letter-spacing:.1em;}

  /* ============ NAV ============ */
  .nav{
    display:flex;align-items:center;justify-content:space-between;
    padding:16px 18px;max-width:480px;margin:0 auto;
  }
  .logo{display:flex;align-items:center;gap:7px;}
  .logo img{height:26px;width:auto;display:block;}
  .logo-drops{
    font-weight:700;font-size:15px;
    color:var(--ink);letter-spacing:.14em;text-transform:uppercase;
    padding-top:2px;
  }
  .nav-pill{
    font-weight:700;font-size:11px;
    background:var(--pressed);color:var(--white);
    border-radius:999px;padding:6px 12px;letter-spacing:.04em;
  }

  .pills{display:flex;gap:8px;flex-wrap:wrap;}
  .pill{
    font-weight:700;font-size:12px;
    border-radius:999px;padding:6px 14px;
  }
  .pill.red{background:var(--pressed);color:var(--white);}

  .btn{
    display:block;width:100%;border:none;cursor:pointer;
    font-family:'Jost',sans-serif;font-weight:800;font-size:18px;
    border-radius:999px;padding:16px;text-align:center;
    transition:transform .1s;
  }
  .btn:active{transform:scale(.98);}
  .btn.primary{background:var(--orange);color:var(--white);box-shadow:0 8px 22px rgba(242,111,33,.4);}

  /* ============ PRODUCT ============ */
  .prod-img{
    border-radius:24px;aspect-ratio:1/1;position:relative;overflow:hidden;
    background:#F3EADB;margin-bottom:18px;
  }
  .prod-img img{width:100%;height:100%;object-fit:cover;display:block;}
  .flash{position:absolute;top:12px;left:12px;}
  .prod-img img.hero-badge{
    position:absolute;right:14px;bottom:14px;width:88px;height:88px;
    left:auto;top:auto;object-fit:contain;
    border-radius:50%;box-shadow:0 6px 18px rgba(43,32,23,.3);
    border:3px solid var(--white);
  }
  .prod-title{font-size:28px;font-weight:800;line-height:1.1;margin-bottom:6px;}
  .prod-collab{display:flex;align-items:center;gap:9px;font-size:13px;font-weight:600;color:#6b6259;margin-bottom:14px;}
  .prod-collab b{color:var(--pressed);}
  .prod-collab .logos{display:flex;flex-shrink:0;}
  .prod-collab .logos img{width:30px;height:30px;border-radius:50%;border:2px solid var(--white);box-shadow:0 2px 8px rgba(43,32,23,.16);display:block;}
  .prod-collab .logos img+img{margin-left:-8px;}
  .price-row{display:flex;align-items:baseline;gap:10px;margin-bottom:18px;}
  .price{font-weight:800;font-size:32px;color:var(--ink);}
  .price-note{font-size:12.5px;color:#6b6259;font-weight:500;}

  .includes{background:var(--white);border-radius:20px;padding:18px;margin-bottom:14px;}
  .includes h3{font-size:16px;margin-bottom:12px;}
  .inc-item{
    display:flex;gap:10px;align-items:flex-start;
    font-size:13.5px;line-height:1.5;margin-bottom:10px;color:#443c35;
  }
  .inc-item:last-child{margin-bottom:0;}
  .inc-check{color:var(--orange);font-weight:800;flex-shrink:0;}

  .redeem-strip{background:var(--ink);border-radius:20px;padding:18px;margin-bottom:14px;}
  .redeem-strip h3{color:var(--white);font-size:15px;margin-bottom:10px;}
  .redeem-strip p{color:rgba(255,255,255,.72);font-size:13px;line-height:1.6;}
  .redeem-strip p b{color:var(--orange);}

  /* story cards */
  .story{background:var(--white);border-radius:20px;overflow:hidden;margin-bottom:14px;}
  .story img{width:100%;aspect-ratio:16/10;object-fit:cover;}
  .story .story-body{padding:16px 18px 18px;}
  .story h3{font-size:16px;margin-bottom:8px;}
  .story p{font-size:13.5px;line-height:1.6;color:#443c35;}
  .story p b{color:var(--pressed);}
  .story .press{font-size:11.5px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:#8a8177;margin-top:10px;}

  /* collection slot picker */
  .slotcard{background:var(--white);border-radius:20px;padding:18px;margin-bottom:14px;}
  .slotcard h3{font-size:16px;margin-bottom:4px;}
  .slot-note{font-size:12.5px;color:#6b6259;margin-bottom:14px;}
  .slot-days{display:flex;gap:8px;margin-bottom:12px;}
  .slot-day{
    flex:1;border:2px solid #E5D9C6;border-radius:14px;background:var(--white);
    font-family:'Jost',sans-serif;font-weight:700;font-size:13px;color:var(--ink);
    padding:10px 4px;text-align:center;cursor:pointer;line-height:1.3;
  }
  .slot-day span{display:block;font-weight:500;font-size:11px;color:#6b6259;}
  .slot-day.sel{border-color:var(--pressed);background:#FBF1F0;}
  .slot-hours{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;}
  .slot-hour{
    border:2px solid #E5D9C6;border-radius:12px;background:var(--white);
    font-family:'Jost',sans-serif;font-weight:600;font-size:13px;color:var(--ink);
    padding:10px 2px;text-align:center;cursor:pointer;
  }
  .slot-hour.sel{border-color:var(--pressed);background:var(--pressed);color:var(--white);}
  .slot-hour.full{opacity:.4;cursor:not-allowed;text-decoration:line-through;}
  .slot-hour em{display:block;font-style:normal;font-size:9.5px;font-weight:600;color:var(--orange);}
  .slot-hour.sel em{color:rgba(255,255,255,.85);}
  .slot-hour.full em{color:#8a8177;text-decoration:none;}
  .slot-picked{font-size:12.5px;font-weight:600;color:#6b6259;margin-top:12px;text-align:center;}
  .slot-picked.on{color:var(--pressed);}
  .slotcard.nudge{animation:slotnudge .4s ease;}
  @keyframes slotnudge{0%,100%{transform:translateX(0);}25%{transform:translateX(-6px);}75%{transform:translateX(6px);}}

  .qty-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;}
  .qty-label{font-weight:700;font-size:15px;}
  .qty-cap{font-size:11px;color:#6b6259;font-weight:500;}
  .qty-ctrl{
    display:flex;align-items:center;gap:16px;
    background:var(--white);border-radius:999px;padding:8px 16px;
  }
  .qty-btn{
    width:30px;height:30px;border-radius:50%;border:none;
    background:var(--cream);font-size:18px;font-weight:700;cursor:pointer;
    font-family:'Jost',sans-serif;color:var(--ink);
  }
  .qty-num{font-weight:800;font-size:18px;min-width:20px;text-align:center;}
  .sticky-cta{
    position:sticky;bottom:0;padding:12px 0 6px;
    background:linear-gradient(180deg,transparent,var(--cream) 30%);
  }
  .cta-note{font-size:11.5px;color:#8a8177;text-align:center;padding:8px 0 18px;line-height:1.5;}

  /* partner note */
  .partner-note{
    background:var(--pressed);border-radius:20px;padding:20px 18px;margin:6px 0 18px;
    color:var(--white);
  }
  .partner-note .pn-logos{display:flex;margin-bottom:12px;}
  .partner-note .pn-logos img{width:44px;height:44px;border-radius:50%;border:2px solid rgba(255,255,255,.9);display:block;}
  .partner-note .pn-logos img+img{margin-left:-11px;}
  .partner-note h3{font-size:17px;font-weight:800;margin-bottom:8px;}
  .partner-note p{font-size:13px;line-height:1.65;color:rgba(255,255,255,.88);margin-bottom:8px;}
  .partner-note p:last-child{margin-bottom:0;}
  .partner-note b{color:#FFE1A8;}

  .foot{text-align:center;padding:10px 0 34px;font-size:11.5px;color:#8a8177;}
  .foot b{color:var(--ink);}

  /* ============ DESKTOP ============ */
  @media (min-width: 900px){
    .nav{max-width:1020px;padding:20px 18px;}
    .screen .wrap{max-width:1020px;display:grid;grid-template-columns:1fr 1fr;gap:0 48px;align-items:start;}
    .screen .wrap > *{grid-column:2;}
    .screen .wrap > .prod-img{grid-column:1;grid-row:1 / span 12;position:sticky;top:24px;height:auto;margin-bottom:0;}
    .prod-title{font-size:38px;}
    .price{font-size:40px;}
    .sticky-cta{position:static;background:none;padding:14px 0 0;}
    .foot{max-width:1020px;margin:0 auto;}
  }

  /* deck-style textured background */
  body{background-image:url('data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22240%22%20height%3D%22240%22%3E%3Cfilter%20id%3D%22n%22%3E%3CfeTurbulence%20type%3D%22fractalNoise%22%20baseFrequency%3D%220.8%22%20numOctaves%3D%222%22%20stitchTiles%3D%22stitch%22%2F%3E%3CfeColorMatrix%20type%3D%22matrix%22%20values%3D%220%200%200%200%200.42%200%200%200%200%200.35%200%200%200%200%200.27%200%200%200%200.10%200%22%2F%3E%3C%2Ffilter%3E%3Crect%20width%3D%22240%22%20height%3D%22240%22%20filter%3D%22url%28%23n%29%22%2F%3E%3C%2Fsvg%3E');}
  .bg-scatter{position:absolute;inset:0;overflow:hidden;z-index:0;pointer-events:none;}
  .bg-shape{position:absolute;}
  .bg-shape svg{width:100%;height:100%;display:block;overflow:visible;}

  .acct-btn{display:inline-flex;align-items:center;gap:5px;font-family:'Jost',sans-serif;font-weight:700;font-size:12.5px;
    background:var(--ink);color:var(--white);border-radius:999px;padding:7px 15px;white-space:nowrap;transition:transform .1s,opacity .15s;}
  .acct-btn:hover{opacity:.88;}
  .acct-btn svg{width:14px;height:14px;}

  /* demo toast */
  .toast{
    position:fixed;left:50%;bottom:26px;transform:translateX(-50%) translateY(20px);
    background:var(--ink);color:var(--white);font-size:13px;font-weight:600;
    border-radius:999px;padding:11px 20px;opacity:0;pointer-events:none;
    transition:opacity .25s, transform .25s;z-index:50;white-space:nowrap;
  }
  .toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
</style>
</head>
