<script>
  let q = 1;
  function qty(d){
    q = Math.min(2, Math.max(1, q + d));
    document.getElementById('qtyNum').textContent = q;
    document.getElementById('buyTotal').textContent = 39 * q;
  }
  let toastT;
  function showToast(msg){
    const t = document.getElementById('demoToast');
    t.textContent = msg;
    t.classList.add('show');
    clearTimeout(toastT);
    toastT = setTimeout(() => t.classList.remove('show'), 2600);
  }
  function demoToast(){
    if(!slotSel.day || !slotSel.hour){
      showToast('Pick a collection slot first');
      const c = document.getElementById('slotCard');
      c.scrollIntoView({behavior:'smooth', block:'center'});
      c.classList.remove('nudge'); void c.offsetWidth; c.classList.add('nudge');
      return;
    }
    showToast('Draft demo · would check out with slot: ' + slotSel.day + ', ' + slotSel.hour);
  }

  // ---------- collection slot picker (sample data; see LAUNCH WIRING comment above) ----------
  const SLOT_DAYS = [
    { d:'Fri', date:'21 Aug' },
    { d:'Sat', date:'22 Aug' },
    { d:'Sun', date:'23 Aug' }
  ];
  // per-day hour availability: left = boxes left in that hour (0 = full)
  const SLOT_HOURS = {
    'Fri': [{h:'12pm',left:9},{h:'1pm',left:12},{h:'2pm',left:7},{h:'3pm',left:14},{h:'4pm',left:10},{h:'5pm',left:4},{h:'6pm',left:11}],
    'Sat': [{h:'12pm',left:0},{h:'1pm',left:3},{h:'2pm',left:0},{h:'3pm',left:6},{h:'4pm',left:8},{h:'5pm',left:2},{h:'6pm',left:9}],
    'Sun': [{h:'12pm',left:5},{h:'1pm',left:7},{h:'2pm',left:11},{h:'3pm',left:0},{h:'4pm',left:13},{h:'5pm',left:9},{h:'6pm',left:15}]
  };
  const slotSel = { day:null, hour:null };
  function renderDays(){
    document.getElementById('slotDays').innerHTML = SLOT_DAYS.map(x =>
      '<button type="button" class="slot-day'+(slotSel.day===x.d?' sel':'')+'" data-day="'+x.d+'">'+x.d+'<span>'+x.date+'</span></button>'
    ).join('');
  }
  function renderHours(){
    const box = document.getElementById('slotHours');
    if(!slotSel.day){ box.innerHTML = ''; return; }
    box.innerHTML = SLOT_HOURS[slotSel.day].map(x => {
      const full = x.left <= 0;
      const sel = slotSel.hour === x.h;
      const tag = full ? '<em>Full</em>' : (x.left <= 4 ? '<em>'+x.left+' left</em>' : '<em>&nbsp;</em>');
      return '<button type="button" class="slot-hour'+(sel?' sel':'')+(full?' full':'')+'" data-hour="'+x.h+'"'+(full?' disabled':'')+'>'+x.h+tag+'</button>';
    }).join('');
  }
  function renderPicked(){
    const el = document.getElementById('slotPicked');
    if(slotSel.day && slotSel.hour){
      const d = SLOT_DAYS.find(x => x.d === slotSel.day);
      el.textContent = 'Collecting ' + slotSel.day + ' ' + d.date + ', ' + slotSel.hour + ' to ' + nextHour(slotSel.hour);
      el.classList.add('on');
    } else {
      el.textContent = slotSel.day ? 'Now pick an hour' : 'No slot picked yet';
      el.classList.remove('on');
    }
  }
  function nextHour(h){
    const order = ['12pm','1pm','2pm','3pm','4pm','5pm','6pm','7pm'];
    return order[order.indexOf(h)+1] || '7pm';
  }
  document.getElementById('slotDays').addEventListener('click', e => {
    const b = e.target.closest('[data-day]');
    if(!b) return;
    slotSel.day = b.getAttribute('data-day');
    slotSel.hour = null;
    renderDays(); renderHours(); renderPicked();
  });
  document.getElementById('slotHours').addEventListener('click', e => {
    const b = e.target.closest('[data-hour]');
    if(!b || b.disabled) return;
    slotSel.hour = b.getAttribute('data-hour');
    renderHours(); renderPicked();
  });
  renderDays(); renderHours(); renderPicked();
</script>
<script>
// ---- deck-style halftone shapes, scattered down the page (no tiling, no seams) ----
const HT_COLORS = {pink:'#E7B3AB', gold:'#E4CB8B', teal:'#A9D2C6', peach:'#EDAF83'};
let __uid = 0;
function ht(color){
  const id = 'ht' + (++__uid);
  return {id, def:'<pattern id="'+id+'" width="7" height="7" patternUnits="userSpaceOnUse" patternTransform="rotate(25)"><circle cx="3.5" cy="3.5" r="2.6" fill="'+color+'"/></pattern>'};
}
function svgWrap(inner, def){
  return '<svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"><defs>'+def+'</defs>'+inner+'</svg>';
}
const PIN = 'M100,188 C63,146 22,108 22,70 C22,34 56,12 100,12 C144,12 178,34 178,70 C178,108 137,146 100,188 Z';
const SHAPES = [
  () => { const p = ht(HT_COLORS.pink); return svgWrap('<path d="'+PIN+'" fill="url(#'+p.id+')"/>', p.def); },
  () => { const p = ht(HT_COLORS.gold); return svgWrap('<circle cx="88" cy="88" r="56" fill="none" stroke="url(#'+p.id+')" stroke-width="22"/><rect x="136" y="124" width="58" height="26" rx="13" transform="rotate(45 140 134)" fill="url(#'+p.id+')"/>', p.def); },
  () => { const p = ht(HT_COLORS.teal); return svgWrap('<circle cx="88" cy="88" r="54" fill="none" stroke="url(#'+p.id+')" stroke-width="32"/><circle cx="88" cy="88" r="20" fill="none" stroke="url(#'+p.id+')" stroke-width="12"/><rect x="134" y="122" width="64" height="34" rx="17" transform="rotate(45 140 134)" fill="url(#'+p.id+')"/>', p.def); },
  () => { const p = ht(HT_COLORS.gold); return svgWrap('<path d="'+PIN+'" fill="none" stroke="url(#'+p.id+')" stroke-width="20"/>', p.def); },
  () => { const p = ht(HT_COLORS.peach); return svgWrap('<path d="M16,192 A84,84 0 0 1 184,192 Z" fill="url(#'+p.id+')"/>', p.def); },
  () => { const p = ht(HT_COLORS.teal); return svgWrap('<path d="'+PIN+'" fill="none" stroke="url(#'+p.id+')" stroke-width="20"/>', p.def); },
];
function mulberry32(a){return function(){a|=0;a=a+0x6D2B79F5|0;let t=Math.imul(a^a>>>15,1|a);t=t+Math.imul(t^t>>>7,61|t)^t;return((t^t>>>14)>>>0)/4294967296;};}
function scatterBg(){
  const holder = document.getElementById('bgScatter');
  if(!holder) return;
  const rnd = mulberry32(7);
  const W = document.documentElement.clientWidth;
  const foot = document.querySelector('footer');
  const maxY = (foot ? foot.offsetTop : document.body.scrollHeight) - 320;
  holder.innerHTML = '';
  __uid = 0;
  const scale = W < 720 ? 0.62 : 1;
  let y = 60 + rnd()*160;
  let side = rnd() < .5;
  let i = 0;
  while(y < maxY){
    const size = (240 + rnd()*180) * scale;
    const x = side ? -size*(0.25 + rnd()*0.25) : W - size*(0.5 + rnd()*0.3);
    const rot = rnd()*44 - 22;
    const d = document.createElement('div');
    d.className = 'bg-shape';
    d.style.cssText = 'top:'+y+'px;left:'+x+'px;width:'+size+'px;height:'+size+'px;transform:rotate('+rot+'deg);opacity:'+(0.5 + rnd()*0.15);
    d.innerHTML = SHAPES[i % SHAPES.length]();
    holder.appendChild(d);
    y += 300 + size*0.5 + rnd()*240;
    side = !side;
    i++;
  }
}
window.addEventListener('load', () => { scatterBg(); setTimeout(scatterBg, 700); });
window.addEventListener('resize', () => { clearTimeout(window.__sbg); window.__sbg = setTimeout(scatterBg, 200); });
</script>
